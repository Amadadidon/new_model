{% for post in posts %}
  <div class="post">
    <p><b>{{ post.author.username }}</b></p>
    <p>{{ post.content }}</p>
    {% if post.image %}
      <img src="{{ url_for('static', filename='uploads/' ~ post.image) }}" alt="Post image">
    {% endif %}
    <p>{{ post.timestamp.strftime("%Y-%m-%d %H:%M") }}</p>
    <form action="{{ url_for('like_post', post_id=post.id) }}" method="POST">
      <button type="submit">Like ({{ post.likes }})</button>
    </form>
    <!-- Comments -->
    <ul>
      {% for comment in post.comments %}
        <li><b>{{ comment.user.username }}</b>: {{ comment.content }}</li>
      {% endfor %}
    </ul>
    <form action="{{ url_for('add_comment', post_id=post.id) }}" method="POST">
      <input type="text" name="comment" placeholder="Add a comment">
      <button type="submit">Comment</button>
    </form>
  </div>
{% else %}
  <p>No posts yet.</p>
{% endfor %}{% for post in posts %}
